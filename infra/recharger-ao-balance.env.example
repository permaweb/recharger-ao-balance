# Copy to /etc/default/recharger-ao-balance and edit paths if needed.

APP_DIR=/opt/recharger-ao-balance
HB_CONFIG=/opt/recharger-ao-balance/config.json
HB_PRELOADED_STORE=/opt/recharger-ao-balance/_build/preloaded-store

# Usually leave unset: start-recharger-node.sh derives it from
# _build/hb_preloaded_index.hrl after `rebar3 device preload`.
# HB_PRELOADED_DEVICES_INDEX=
